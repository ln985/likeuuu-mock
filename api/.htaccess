# likeuuu Mock Server - 虚拟主机路由配置
# 大部分虚拟主机默认支持这些配置

# 启用必要选项
Options +FollowSymLinks
Options +MultiViews

# 默认首页
DirectoryIndex index.php

# 允许传递路径信息给 PHP
AcceptPathInfo On

# 重写规则
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 如果请求的是目录且有尾随斜杠，使用 index.php
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)/$ $1/index.php [L]
    
    # 如果文件不存在（无 .php 后缀），尝试加 .php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L]
    
    # 将动态路径（数字）传递给同级 index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(\d+)/?$ index.php [QSA,L]
</IfModule>
